# ========================
# Application Configuration
# ========================
NODE_ENV=production
PORT=4000

# ========================
# Security
# ========================
# Generate a strong secret key for sessions and JWT
APP_SECRET=your_secure_app_secret_here
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5176,https://fees-manager.netlify.app

# ========================
# Database (PostgreSQL)
# ========================
DATABASE_URL=postgres://username:password@db:5432/your_database_name
# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=20

# ========================
# Redis
# ========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_TLS=false

# ========================
# WPPConnect
# ========================
# Internal Docker network URL for WPPConnect
WPPCONNECT_URL=http://localhost:4000
# Secret key for WPPConnect authentication
WPPCONNECT_SECRET=your_wppconnect_secret_here
# Optional: Enable token-based authentication
WPPCONNECT_TOKEN=your_wppconnect_token_here

# ========================
# Rate Limiting
# ========================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100   # Max requests per window

# ========================
# Logging
# ========================
LOG_LEVEL=info
LOG_FORMAT=combined
LOG_FILE=logs/app.log
ERROR_LOG_FILE=logs/error.log

# ========================
# Session
# ========================
SESSION_SECRET=your_session_secret_here
SESSION_MAX_AGE=86400  # 24 hours in seconds

# ========================
# Email (if applicable)
# ========================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false  # true for 465, false for other ports
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_email_password
# EMAIL_FROM="Your App <noreply@yourdomain.com>"

# ========================
# Redis Database
# ========================
REDIS_URL=redis://:your_redis_password@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_here

# ========================
# API Configuration
# ========================
NODE_ENV=production
PORT=4000
API_URL=http://localhost:4000
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# ========================
# WhatsApp Settings
# ========================
WHATSAPP_SESSION_DIR=./sessions
WHATSAPP_WEB_VERSION=2.2412.54
WHATSAPP_QR_TIMEOUT=300000 # 5 minutes in milliseconds

# ========================
# Security
# ========================
TRUST_PROXY=1 # Set to 1 if behind a proxy (e.g., Nginx, Cloudflare)

# ========================
# Debugging (set to 'true' for development, 'false' in production)
# ========================
DEBUG=false
