# ========================
# Application Configuration
# ========================
NODE_ENV=production
PORT=4000

# ========================
# Security
# ========================
# Generate a strong secret key for sessions and JWT
APP_SECRET=your_secure_app_secret_here
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# ========================
# Database (PostgreSQL)
# ========================
DATABASE_URL=postgres://username:password@db:5432/your_database_name
# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=20

# ========================
# Redis
# ========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password
REDIS_TLS=false

# ========================
# WPPConnect
# ========================
# Internal Docker network URL for WPPConnect
WPPCONNECT_URL=http://wppconnect:21465
# Secret key for WPPConnect authentication
WPPCONNECT_SECRET=your_secure_wppconnect_secret
# Optional: Enable token-based authentication
WPPCONNECT_TOKEN=

# ========================
# Rate Limiting
# ========================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100   # Max requests per window

# ========================
# Logging
# ========================
LOG_LEVEL=info
LOG_FILE=logs/app.log
ERROR_LOG_FILE=logs/error.log

# ========================
# Session
# ========================
SESSION_SECRET=your_session_secret_here
SESSION_MAX_AGE=86400000  # 24 hours in milliseconds

# ========================
# Email (if applicable)
# ========================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false  # true for 465, false for other ports
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_email_password
# EMAIL_FROM="Your App <noreply@yourdomain.com>"

# ========================
# Redis Database
# ========================
REDIS_URL=redis://:your_redis_password@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password

# ========================
# API Configuration
# ========================
NODE_ENV=production
PORT=4000
API_URL=http://localhost:4000
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# ========================
# WPPConnect
# ========================
WPPCONNECT_URL=http://wppconnect:21465
WPPCONNECT_SECRET=your_secure_wppconnect_secret
WPPCONNECT_TOKEN=your_secure_wppconnect_token

# ========================
# CORS & Security
# ========================
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# ========================
# Rate Limiting
# ========================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ========================
# SSL (for production)
# ========================
LETSENCRYPT_EMAIL=your-email@example.com
DOMAIN=your-domain.com

# ========================
# Webhook & Storage
# ========================
WEBHOOK_URL=your_webhook_url
S3_ENABLED=false

# ========================
# Logging
# ========================
LOG_LEVEL=info
LOG_CONSOLE=true
LOG_CONSOLE_LEVEL=info

# ========================
# Monitoring (optional)
# ========================
# SENTRY_DSN=your_sentry_dsn_here
# NEW_RELIC_LICENSE_KEY=your_new_relic_key

# ========================
# Feature Flags
# ========================
# ENABLE_MAINTENANCE_MODE=false
# ENABLE_REGISTRATION=true

# ========================
